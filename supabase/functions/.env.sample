# Edge function environment variables for local development
# Copy to supabase/functions/.env and adjust values
#
# IMPORTANT: Use "kong:8000" as the Supabase hostname (NOT 127.0.0.1:54321).
# Edge functions run inside Docker and must use the internal Docker network hostname.
#
# After creating this file, restart Supabase:
#   supabase stop && supabase start

# The URL to the GeoJson file of the pumps (internal Docker network URL)
PUMPS_URL=http://kong:8000/storage/v1/object/public/data_assets/pumps.geojson

# CORS settings
ALLOWED_ORIGIN=http://localhost:5173

# SMTP settings for sending emails (for the contact feature)
SMTP_HOST=host.docker.internal
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=your_mail@test.com
SMTP_PORT=1025
SMTP_SECURE=false
